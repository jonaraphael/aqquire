# WorkOS AuthKit Configuration (Frontend)
VITE_WORKOS_CLIENT_ID=YOUR-WORKOS-CLIENT-ID
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/callback

# Optional local demo mode (bypasses WorkOS auth)
# VITE_DEMO_MODE=1

# Optional router mode for static hosting
# VITE_ROUTER_MODE=hash

# Optional Vite base path (set automatically in GitHub Actions Pages workflow)
# VITE_BASE_PATH=/your-repo-name/

# Optional OpenAI browser key for live AQQUIRE target detection + online product lookup
# WARNING: VITE_ vars are embedded into client bundles; do not use production secrets here.
# VITE_OPENAI_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# VITE_OPENAI_VISION_MODEL=gpt-5.2
# VITE_OPENAI_SEARCH_MODEL=gpt-5.2

# Optional Stripe setup redirect (used by the Profile "Stripe Setup" button)
# VITE_STRIPE_SETUP_URL=https://your-stripe-setup-link.example
